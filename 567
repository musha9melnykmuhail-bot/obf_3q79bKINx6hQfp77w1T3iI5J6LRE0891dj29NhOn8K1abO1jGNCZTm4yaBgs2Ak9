    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local TglBtn, Circle = CreateSoftToggle(stateTable[field])
    TglBtn.Parent = TopContainer
    TglBtn.Position = UDim2.new(1, -38, 0.5, -7)
    
    local function DoToggle()
        stateTable[field] = not stateTable[field]
        local state = stateTable[field]
        TweenService:Create(Circle, TweenInfo.new(0.08), {Position = state and UDim2.new(1, -12, 0.5, -4) or UDim2.new(0, 3, 0.5, -4)}):Play()
        TweenService:Create(TglBtn, TweenInfo.new(0.08), {BackgroundColor3 = state and NVL_Colors.Accent or Color3.fromRGB(40, 48, 68)}):Play()
        UpdatePreviewUI()
    end
    
    TglBtn.MouseButton1Click:Connect(DoToggle)
end

