local function UpdatePreviewUI()
    if ESPConfig.MasterSwitch then
        if ESPConfig.Boxes then
            SimBoxOutline.Enabled = not ESPConfig.CornerBoxes
            SimCorners.Visible = ESPConfig.CornerBoxes
        else
            SimBoxOutline.Enabled = false
            SimCorners.Visible = false
        end
        SimBoxOutline.Color = ESPConfig.BoxesColor
        SimBoxOutline.Thickness = ESPConfig.BoxesThick
        for _, c in pairs(SimCorners:GetChildren()) do c.BackgroundColor3 = ESPConfig.BoxesColor end

        SimName.Visible = ESPConfig.Names
        SimName.TextColor3 = ESPConfig.NamesColor
        SimDist.Visible = ESPConfig.Distance
        SimDist.TextColor3 = ESPConfig.DistanceColor
        SimHealth.Visible = ESPConfig.Health
        SimHealth.BackgroundColor3 = ESPConfig.HealthColor
        SimWeapon.Visible = ESPConfig.Weapon
        SimWeapon.TextColor3 = ESPConfig.WeaponColor
        
        SimSkeleton.Visible = ESPConfig.Skeleton
        for _, part in pairs(SimSkeleton:GetChildren()) do
            if part:IsA("Frame") then part.BackgroundColor3 = ESPConfig.SkeletonColor end
        end
        SimChamsFill.BackgroundTransparency = ESPConfig.Chams and 0.7 or 1
        SimChamsFill.BackgroundColor3 = ESPConfig.ChamsColor
    else
        SimBoxOutline.Enabled = false
        SimCorners.Visible = false
        SimName.Visible = false
        SimDist.Visible = false
        SimHealth.Visible = false
        SimWeapon.Visible = false
        SimSkeleton.Visible = false
        SimChamsFill.BackgroundTransparency = 1
    end
end

