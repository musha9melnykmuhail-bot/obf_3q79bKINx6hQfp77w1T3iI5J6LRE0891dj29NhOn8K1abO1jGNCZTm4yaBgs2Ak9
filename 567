local function CreateDrawingESP(player)
    if ESPCache[player] then return end
    local Box = Drawing.new("Square") Box.Color = ESPConfig.BoxesColor Box.Thickness = ESPConfig.BoxesThick Box.Visible = false
    local Tracer = Drawing.new("Line") Tracer.Color = ESPConfig.TracersColor Tracer.Thickness = 1.2
    local NameTag = Drawing.new("Text") NameTag.Color = ESPConfig.NamesColor NameTag.Size = 13 NameTag.Center = true NameTag.Outline = true
    local DistTag = Drawing.new("Text") DistTag.Color = ESPConfig.DistanceColor DistTag.Size = 12 DistTag.Center = true DistTag.Outline = true
    local HealthBar = Drawing.new("Square") HealthBar.Color = ESPConfig.HealthColor HealthBar.Filled = true
    local WeaponTag = Drawing.new("Text") WeaponTag.Color = ESPConfig.WeaponColor WeaponTag.Size = 12 WeaponTag.Center = true WeaponTag.Outline = true

    local SkeletonLines = {}
    for i = 1, 7 do
        local line = Drawing.new("Line") line.Color = ESPConfig.SkeletonColor line.Thickness = ESPConfig.SkeletonThick line.Visible = false
        table.insert(SkeletonLines, line)
    end

    local CornerLines = {}
    for i = 1, 8 do
        local cl = Drawing.new("Line") cl.Color = ESPConfig.BoxesColor cl.Thickness = ESPConfig.BoxesThick cl.Visible = false
        table.insert(CornerLines, cl)
    end
    
    local HighlightObj = Instance.new("Highlight") HighlightObj.FillColor = ESPConfig.ChamsColor HighlightObj.FillTransparency = 0.5 HighlightObj.Enabled = false HighlightObj.Parent = ToriumGui
    
    ESPCache[player] = {
        Box = Box, Tracer = Tracer, NameTag = NameTag, DistTag = DistTag, Corners = CornerLines,
        HealthBar = HealthBar, WeaponTag = WeaponTag, Skeleton = SkeletonLines, Highlight = HighlightObj
    }
end

local function ClearDrawingESP(player)
    if ESPCache[player] then
        pcall(function()
            ESPCache[player].Box:Remove() ESPCache[player].Tracer:Remove() ESPCache[player].NameTag:Remove() ESPCache[player].DistTag:Remove()
            ESPCache[player].HealthBar:Remove() ESPCache[player].WeaponTag:Remove()
            for _, l in pairs(ESPCache[player].Skeleton) do l:Remove() end 
            for _, cl in pairs(ESPCache[player].Corners) do cl:Remove() end
            ESPCache[player].Highlight:Destroy()
        end)
        ESPCache[player] = nil
    end
end

