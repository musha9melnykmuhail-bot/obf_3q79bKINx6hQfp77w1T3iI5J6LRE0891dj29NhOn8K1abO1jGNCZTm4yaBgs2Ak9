        elseif BindModes[field] == "toggle" then
            BindModes[field] = "off"
            if stateTable then
                stateTable[field] = false
                if UpdatePreviewUI then UpdatePreviewUI() end
            end
        else
            BindModes[field] = "hold"
        end
        modeBtn.Text = BindModeNames[BindModes[field]]
    end)
    
    -- Кейбинд
    local bindLabel = Instance.new("TextLabel", cloud)
    bindLabel.Size = UDim2.new(0, 40, 0, 18)
    bindLabel.Position = UDim2.new(0.05, 0, 0, 52)
    bindLabel.BackgroundTransparency = 1
    bindLabel.Text = "Bind:"
    bindLabel.TextColor3 = NVL_Colors.TextDark
    bindLabel.Font = MainFont
    bindLabel.TextSize = 10
    bindLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local bindBtn = Instance.new("TextButton", cloud)
    bindBtn.Size = UDim2.new(0, 50, 0, 18)
    bindBtn.Position = UDim2.new(0.4, 0, 0, 52)
    bindBtn.BackgroundColor3 = Color3.fromRGB(30, 38, 55)
