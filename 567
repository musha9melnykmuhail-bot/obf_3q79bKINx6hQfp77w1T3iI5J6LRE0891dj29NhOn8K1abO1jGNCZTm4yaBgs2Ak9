    RowStroke.Color = NVL_Colors.Border
    
    local TopContainer = Instance.new("Frame", MainRow)
    TopContainer.Size = UDim2.new(1, 0, 0, 40)
    TopContainer.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", TopContainer)
    Label.Size = UDim2.new(1, -125, 1, 0)
