    hexBox.Size = UDim2.new(0, 80, 0, 22)
    hexBox.Position = UDim2.new(0, 10, 0, 118)
    hexBox.BackgroundColor3 = NVL_Colors.ChildBg
    hexBox.Text = "#FFFFFF"
    hexBox.TextColor3 = NVL_Colors.Text
    hexBox.Font = MainFont
    hexBox.TextSize = 11
    hexBox.BorderSizePixel = 0
    hexBox.ZIndex = 51
    local hexCorner = Instance.new("UICorner", hexBox)
    hexCorner.CornerRadius = UDim.new(0, 4)
    
    -- Предустановленные цвета
    local presetColors = {
        Color3.fromRGB(255,255,255), Color3.fromRGB(255,0,0),
        Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255),
        Color3.fromRGB(255,255,0), Color3.fromRGB(255,0,255),
        Color3.fromRGB(0,255,255), Color3.fromRGB(255,128,0)
    }
    
    for i, color in ipairs(presetColors) do
        local btn = Instance.new("TextButton", frame)
        btn.Size = UDim2.new(0, 18, 0, 18)
        btn.Position = UDim2.new(0, 100 + (i-1) * 22, 0, 118)
        btn.BackgroundColor3 = color
        btn.Text = ""
        btn.BorderSizePixel = 0
        btn.ZIndex = 51
        local btnCorner = Instance.new("UICorner", btn)
        btnCorner.CornerRadius = UDim.new(0, 4)
        btn.MouseButton1Click:Connect(function()
            local h, s, v = Color3.toHSV(color)
            currentHue = h
            currentSat = s
            currentLight = v
            UpdateDisplay()
        end)
    end
    
    local currentHue = 0.58
    local currentSat = 1
    local currentLight = 0.5
    local dragging = false
    
    local function UpdateDisplay()
        local color = Color3.fromHSV(currentHue, currentSat, currentLight)
        colorField.BackgroundColor3 = Color3.fromHSV(currentHue, 1, 1)
        selector.Position = UDim2.new(currentSat, -5, 1 - currentLight, -5)
        hueSelector.Position = UDim2.new(0, -1, currentHue, -2)
        hexBox.Text = string.format("#%02X%02X%02X", color.R*255, color.G*255, color.B*255)
        callback(color)
    end
    
    colorField.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement and frame.Visible then
            local relX = math.clamp((input.Position.X - colorField.AbsolutePosition.X) / colorField.AbsoluteSize.X, 0, 1)
            local relY = math.clamp((input.Position.Y - colorField.AbsolutePosition.Y) / colorField.AbsoluteSize.Y, 0, 1)
            currentSat = relX
            currentLight = 1 - relY
            UpdateDisplay()
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    hueSlider.MouseButton1Down:Connect(function()
        local hueConn
        hueConn = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement and frame.Visible then
                local relY = math.clamp((input.Position.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                currentHue = relY
                UpdateDisplay()
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                hueConn:Disconnect()
            end
        end)
    end)
    
    hexBox.FocusLost:Connect(function()
        local hex = hexBox.Text:gsub("#", "")
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2), 16) or 255
            local g = tonumber(hex:sub(3,4), 16) or 255
            local b = tonumber(hex:sub(5,6), 16) or 255
            local color = Color3.fromRGB(r, g, b)
            local h, s, v = Color3.toHSV(color)
            currentHue = h
            currentSat = s
            currentLight = v
            UpdateDisplay()
        end
    end)
    
    UpdateDisplay()
    return frame
end

