        ThickLabel.TextXAlignment = Enum.TextXAlignment.Left
        ThickLabel.TextSize = 11

        local ThickTrack = Instance.new("TextButton", Drawer)
        ThickTrack.Size = UDim2.new(1, -130, 0, 6)
        ThickTrack.Position = UDim2.new(0, 115, 0, (styleMode == "Boxes") and 197 or 49)
        ThickTrack.BackgroundColor3 = Color3.fromRGB(50, 58, 78)
        ThickTrack.Text = ""
        ThickTrack.BorderSizePixel = 0
        local ThickCorner = Instance.new("UICorner", ThickTrack)
        ThickCorner.CornerRadius = UDim.new(0, 3)
        local ThickFill = Instance.new("Frame", ThickTrack)
        ThickFill.Size = UDim2.new(0.4, 0, 1, 0)
        ThickFill.BackgroundColor3 = NVL_Colors.Accent
        ThickFill.BorderSizePixel = 0
        local ThickFillCorner = Instance.new("UICorner", ThickFill)
        ThickFillCorner.CornerRadius = UDim.new(0, 3)

        ThickTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                ActiveSlider = function(mx)
                    local pct = math.clamp((mx - ThickTrack.AbsolutePosition.X) / ThickTrack.AbsoluteSize.X, 0, 1)
                    ThickFill.Size = UDim2.new(pct, 0, 1, 0)
                    ESPConfig[field .. "Thick"] = 1 + (pct * 4)
                    UpdatePreviewUI()
                end
                ActiveSlider(input.Position.X)
            end
        end)

        if styleMode == "Boxes" then
            local CornLabel = Instance.new("TextLabel", Drawer)
            CornLabel.Size = UDim2.new(0, 120, 0, 20)
            CornLabel.Position = UDim2.new(0, 10, 0, 160)
            CornLabel.BackgroundTransparency = 1
            CornLabel.Text = "Corner Box Layout"
            CornLabel.TextColor3 = NVL_Colors.Text
            CornLabel.Font = MainFont
            CornLabel.TextSize = 11
            CornLabel.TextXAlignment = Enum.TextXAlignment.Left

            local CornTgl = Instance.new("TextButton", Drawer)
            CornTgl.Size = UDim2.new(0, 24, 0, 13)
            CornTgl.Position = UDim2.new(0, 140, 0, 163)
            CornTgl.BackgroundColor3 = ESPConfig.CornerBoxes and NVL_Colors.Accent or Color3.fromRGB(45,54,75)
            CornTgl.Text = ""
