local function UpdateWatermark()
    if not ScreenWatermark.Visible then return end
    local timeStr = SettingsConfig.ShowSeconds and os.date("%X") or os.date("%H:%M")
    local fps = math.floor(1 / RunService.RenderStepped:Wait())
    local ping = Stats:FindFirstChild("Network") and Stats.Network:FindFirstChild("Ping") and Stats.Network.Ping.Value or 0
    local configName = ProfileConfig.ConfigName or "Default"
    
    local text = ""
    text = text .. SettingsConfig.WatermarkText
    if SettingsConfig.ShowPlayerName then text = text .. " | " .. string.upper(PlayerName) end
    text = text .. " | " .. timeStr
    if SettingsConfig.ShowFPS then text = text .. " | FPS: " .. tostring(fps) end
    if SettingsConfig.ShowPing then text = text .. " | PING: " .. tostring(math.floor(ping)) end
    if SettingsConfig.ShowConfig then text = text .. " | CFG: " .. configName end
    
    WMText.Text = text
    WMAvatar.Visible = SettingsConfig.ShowAvatar
    WMText.Position = SettingsConfig.ShowAvatar and UDim2.new(0, 36, 0, 0) or UDim2.new(0, 6, 0, 0)
end

