            Drawer.Visible = Expanded
            local targetHeight = Expanded and (36 + DrawerHeight + (styleMode == "Boxes" and 60 or 0)) or 36
            TweenService:Create(MainRow, TweenInfo.new(0.12), {Size = UDim2.new(1, -6, 0, targetHeight)}):Play()
        end)
    end

    local function DoToggle()
        if BindModes[field] == "off" then
            stateTable[field] = false
            TweenService:Create(Circle, TweenInfo.new(0.08), {Position = UDim2.new(0, 3, 0.5, -4)}):Play()
            TweenService:Create(TglBtn, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(40, 48, 68)}):Play()
            if UpdatePreviewUI then UpdatePreviewUI() end
            return
        end
        
        stateTable[field] = not stateTable[field]
        local state = stateTable[field]
        TweenService:Create(Circle, TweenInfo.new(0.08), {Position = state and UDim2.new(1, -12, 0.5, -4) or UDim2.new(0, 3, 0.5, -4)}):Play()
        TweenService:Create(TglBtn, TweenInfo.new(0.08), {BackgroundColor3 = state and NVL_Colors.Accent or Color3.fromRGB(40, 48, 68)}):Play()
        if UpdatePreviewUI then UpdatePreviewUI() end
    end

    TglBtn.MouseButton1Click:Connect(DoToggle)

    local keyState = false
    UserInputService.InputBegan:Connect(function(input, gp)
        if not gp and not IsBindingKey then
            if input.UserInputType == Enum.UserInputType.Keyboard and Keybinds[field] == input.KeyCode then
                if BindModes[field] == "hold" then
                    keyState = true
                    DoToggle()
                elseif BindModes[field] == "toggle" then
                    DoToggle()
                end
            end
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard and Keybinds[field] == input.KeyCode then
            if BindModes[field] == "hold" and keyState then
                keyState = false
                DoToggle()
            end
        end
    end)
end

