local function CreateSoftToggle(state)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 28, 0, 15)
    btn.BackgroundColor3 = state and NVL_Colors.Accent or Color3.fromRGB(40, 48, 68)
    btn.Text = ""
    btn.BorderSizePixel = 0
    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim.new(0, 12)
    local circle = Instance.new("Frame", btn)
    circle.Size = UDim2.new(0, 9, 0, 9)
    circle.Position = state and UDim2.new(1, -12, 0.5, -4) or UDim2.new(0, 3, 0.5, -4)
    circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    circle.BorderSizePixel = 0
    local circleCorner = Instance.new("UICorner", circle)
    circleCorner.CornerRadius = UDim.new(1, 0)
    return btn, circle
end

