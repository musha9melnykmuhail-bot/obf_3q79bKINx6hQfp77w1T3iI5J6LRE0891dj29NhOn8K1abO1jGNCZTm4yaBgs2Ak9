    ValueLabel.Font = MainFontBold
    ValueLabel.TextSize = 12
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

    local SliderTrack = Instance.new("TextButton", Box)
    SliderTrack.Size = UDim2.new(1, -24, 0, 5)
    SliderTrack.Position = UDim2.new(0, 12, 1, -12)
    SliderTrack.BackgroundColor3 = Color3.fromRGB(42, 50, 70)
    SliderTrack.Text = ""
    SliderTrack.BorderSizePixel = 0
    local TrackCorner = Instance.new("UICorner", SliderTrack)
    TrackCorner.CornerRadius = UDim.new(0, 3)

    local SliderFill = Instance.new("Frame", SliderTrack)
    SliderFill.Size = UDim2.new((cfg[field] - min)/(max - min), 0, 1, 0)
    SliderFill.BackgroundColor3 = NVL_Colors.Accent
    SliderFill.BorderSizePixel = 0
    local FillCorner = Instance.new("UICorner", SliderFill)
    FillCorner.CornerRadius = UDim.new(0, 3)

    SliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            ActiveSlider = function(mx)
                local pct = math.clamp((mx - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (pct * (max - min)))
                cfg[field] = val
                ValueLabel.Text = tostring(val) .. (isPercent and "%" or "")
                SliderFill.Size = UDim2.new(pct, 0, 1, 0)
            end
            ActiveSlider(input.Position.X)
        end
    end)
end

