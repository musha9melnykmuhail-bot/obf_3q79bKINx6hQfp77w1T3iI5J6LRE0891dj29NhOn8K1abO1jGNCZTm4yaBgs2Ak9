local function CreateTabButton(name, order)
    local TabButton = Instance.new("TextButton", TabContainer)
    TabButton.Name = name .. "Tab"
    TabButton.Size = UDim2.new(1, -10, 0, 38)
    TabButton.Position = UDim2.new(0, 5, 0, 0)
    TabButton.BackgroundTransparency = 1
    TabButton.Text = ""
    TabButton.LayoutOrder = order
    TabButton.BorderSizePixel = 0
    local TabCorner = Instance.new("UICorner", TabButton)
    TabCorner.CornerRadius = UDim.new(0, 4)
    
    local IconImg = Instance.new("ImageLabel", TabButton)
    IconImg.Name = "Icon"
    IconImg.Size = UDim2.new(0, 16, 0, 16)
    IconImg.Position = UDim2.new(0, 15, 0.5, -8)
    IconImg.BackgroundTransparency = 1
    IconImg.Image = TabIcons[name]
    IconImg.ImageColor3 = (name == "Aimbot") and Color3.fromRGB(255, 255, 255) or NVL_Colors.TextDark
    
    local TextLbl = Instance.new("TextLabel", TabButton)
    TextLbl.Name = "Text"
    TextLbl.Size = UDim2.new(1, -50, 1, 0)
    TextLbl.Position = UDim2.new(0, 45, 0, 0)
    TextLbl.BackgroundTransparency = 1
    TextLbl.Text = name
    TextLbl.TextColor3 = (name == "Aimbot") and Color3.fromRGB(255, 255, 255) or NVL_Colors.TextDark
    TextLbl.Font = MainFontBold
    TextLbl.TextSize = 13
    TextLbl.TextXAlignment = Enum.TextXAlignment.Left
    
    TabButton.MouseButton1Click:Connect(function()
        CurrentTab = name
        for tName, page in pairs(Pages) do page.Visible = (tName == name) end
        PreviewWindow.Visible = (name == "Visuals")
        
        for _, btn in pairs(TabContainer:GetChildren()) do
            if btn:IsA("TextButton") then
                local icon = btn:FindFirstChild("Icon") local text = btn:FindFirstChild("Text")
                if btn.Name == name .. "Tab" then
                    if text then text.TextColor3 = Color3.fromRGB(255, 255, 255) end
                    if icon then icon.ImageColor3 = Color3.fromRGB(255, 255, 255) end
                    btn.BackgroundTransparency = 0.93
                    btn.BackgroundColor3 = Color3.fromRGB(255,255,255)
                else
                    if text then text.TextColor3 = NVL_Colors.TextDark end
                    if icon then icon.ImageColor3 = NVL_Colors.TextDark end
                    btn.BackgroundTransparency = 1
                end
            end
        end
    end)
    if name == "Aimbot" then
        TabButton.BackgroundTransparency = 0.93
        TabButton.BackgroundColor3 = Color3.fromRGB(255,255,255)
    end
end

