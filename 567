UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if ActiveSlider then
            ActiveSlider(input.Position.X)
        elseif ActiveDragElement then
            local delta = input.Position - DragMouseStart
            local newX = math.clamp(DragOffsetStart.X + delta.X, -120, 120)
            local newY = math.clamp(DragOffsetStart.Y + delta.Y, -180, 180)
            ESPOffsets[ActiveDragElement.Key] = Vector2.new(newX, newY)
            ActiveDragElement.Instance.Position = UDim2.new(0.5, newX, 0.5, newY)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        ActiveSlider = nil
        ActiveDragElement = nil
    end
end)

