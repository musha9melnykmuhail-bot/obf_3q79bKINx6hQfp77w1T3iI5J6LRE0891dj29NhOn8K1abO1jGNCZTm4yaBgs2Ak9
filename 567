    bindBtn.TextSize = 10
    bindBtn.BorderSizePixel = 0
    local bindCorner = Instance.new("UICorner", bindBtn)
    bindCorner.CornerRadius = UDim.new(0, 4)
    
    if Keybinds[field] then
        bindBtn.Text = "[" .. Keybinds[field].Name .. "]"
    end
    
    local isBinding = false
    bindBtn.MouseButton1Click:Connect(function()
        isBinding = true
        bindBtn.Text = "..."
    end)
    bindBtn.MouseButton2Click:Connect(function()
        Keybinds[field] = nil
        bindBtn.Text = "[-]"
    end)
    
    UserInputService.InputBegan:Connect(function(input, gp)
        if isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode
            if key == Enum.KeyCode.Escape or key == Enum.KeyCode.Backspace then
                Keybinds[field] = nil
                bindBtn.Text = "[-]"
            else
                Keybinds[field] = key
                bindBtn.Text = "["..key.Name.."]"
            end
            isBinding = false
        end
    end)
    
    -- Кнопка сброса
    local resetBtn = Instance.new("TextButton", cloud)
    resetBtn.Size = UDim2.new(0, 60, 0, 18)
    resetBtn.Position = UDim2.new(0.35, 0, 0, 78)
    resetBtn.BackgroundColor3 = NVL_Colors.Danger
    resetBtn.BackgroundTransparency = 0.7
    resetBtn.Text = "✕ RESET"
    resetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    resetBtn.Font = MainFont
    resetBtn.TextSize = 9
    resetBtn.BorderSizePixel = 0
    local resetCorner = Instance.new("UICorner", resetBtn)
    resetCorner.CornerRadius = UDim.new(0, 4)
    
    resetBtn.MouseButton1Click:Connect(function()
        Keybinds[field] = nil
        bindBtn.Text = "[-]"
        BindModes[field] = "off"
        modeBtn.Text = "OFF"
        if stateTable then
            stateTable[field] = false
            if UpdatePreviewUI then UpdatePreviewUI() end
        end
        cloud.Visible = false
        CloudOpen[field] = false
    end)
    
    return cloud, modeBtn, bindBtn, resetBtn
end

