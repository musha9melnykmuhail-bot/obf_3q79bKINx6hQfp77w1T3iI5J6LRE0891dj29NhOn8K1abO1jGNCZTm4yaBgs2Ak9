local function GetClosestPlayerToCrosshair()
    local target = nil
    local maxDist = AimbotConfig.FOV
    local mousePos = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(AimbotConfig.TargetPart) then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                if AimbotConfig.TeamCheck and p.Team == LocalPlayer.Team then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(p.Character[AimbotConfig.TargetPart].Position)
                if onScreen then
                    local screenDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if screenDist < maxDist then
                        maxDist = screenDist
                        target = p
                    end
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")

    ScreenWatermark.Visible = SettingsConfig.ShowWatermark
    UpdateWatermark()

    local targetMenuColor = Color3.fromHSV(SettingsConfig.MenuColorHue / 100, 1, 1)
    if targetMenuColor ~= NVL_Colors.Accent then
        local oldColor = NVL_Colors.Accent
        NVL_Colors.Accent = targetMenuColor
        for _, obj in pairs(ToriumGui:GetDescendants()) do
            pcall(function()
                if obj.BackgroundColor3 == oldColor then obj.BackgroundColor3 = targetMenuColor end
                if obj.TextColor3 == oldColor then obj.TextColor3 = targetMenuColor end
            end)
        end
    end

    Lighting.ClockTime = MiscConfig.TimeOfDay

    local rainPart = workspace:FindFirstChild("ToriumWeather")
    if not rainPart then
        rainPart = Instance.new("Part")
        rainPart.Name = "ToriumWeather"
        rainPart.Anchored = true
        rainPart.CanCollide = false
        rainPart.Transparency = 1
        rainPart.Size = Vector3.new(50, 2, 50)
        rainPart.Parent = workspace
        local emitter = Instance.new("ParticleEmitter", rainPart)
        emitter.Name = "Emitter"
        emitter.Rate = 0
    end
    rainPart.Position = Camera.CFrame.Position + Vector3.new(0, 25, 0)
    local em = rainPart:FindFirstChild("Emitter")
    if em then
        if MiscConfig.RainEnabled then
            em.Rate = 500
            em.Color = ColorSequence.new(Color3.fromRGB(150, 150, 255))
            em.Speed = NumberRange.new(50, 70)
            em.Acceleration = Vector3.new(0, -50, 0)
            em.Texture = "rbxassetid://1832101249"
            em.Enabled = true
        elseif MiscConfig.SnowEnabled then
            em.Rate = 200
            em.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
            em.Speed = NumberRange.new(10, 20)
            em.Acceleration = Vector3.new(0, -5, 0)
            em.Texture = "rbxassetid://243664672"
            em.Enabled = true
        else
            em.Rate = 0
            em.Enabled = false
        end
    end

    if myHum then
        if MovementConfig.WalkSpeedEnabled then myHum.WalkSpeed = MovementConfig.WalkSpeedValue else myHum.WalkSpeed = 16 end
        if MovementConfig.JumpPowerEnabled then myHum.UseJumpPower = true myHum.JumpPower = MovementConfig.JumpPowerValue else myHum.JumpPower = 50 end
        if MovementConfig.NoSlowdown and myHum.WalkSpeed < 16 and not MovementConfig.WalkSpeedEnabled then myHum.WalkSpeed = 16 end
        
        if MiscConfig.Bhop and UserInputService:IsKeyDown(Enum.KeyCode.Space) and myHum.MoveDirection.Magnitude > 0 then
            if myHum:GetState() == Enum.HumanoidStateType.Landed or myHum:GetState() == Enum.HumanoidStateType.Running then
                myHum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end

    SetupFly()

    if MovementConfig.Noclip and myChar then
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end

    if MiscConfig.Invisible and myChar then
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.LocalTransparencyModifier = 0.75
            end
        end
    elseif myChar then
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.LocalTransparencyModifier = 0
            end
        end
    end

    -- [+] АНТИ-АИМ ЛОГИКА
    if AntiAimConfig.Enabled and myChar then
        local root = myChar:FindFirstChild("HumanoidRootPart")
        if root then
            local deltaTime = RunService.RenderStepped:Wait()
            
            if AntiAimConfig.Mode == "Random" then
                -- Рандомное вращение
                local speed = AntiAimConfig.RandomSpeed or 10
                AntiAimAngle = AntiAimAngle + (math.random() * 2 - 1) * speed * deltaTime * 10
                
            elseif AntiAimConfig.Mode == "Jitter" then
                -- Джиттер (качание туда-сюда)
                local speed = AntiAimConfig.JitterSpeed or 10
                local maxAngle = AntiAimConfig.JitterAngle or 45
                
                AntiAimAngle = AntiAimAngle + speed * deltaTime * AntiAimDirection * 10
                
                if AntiAimAngle > maxAngle then
                    AntiAimAngle = maxAngle
                    AntiAimDirection = -1
                elseif AntiAimAngle < -maxAngle then
                    AntiAimAngle = -maxAngle
                    AntiAimDirection = 1
                end
            end
            
            -- Применяем поворот к RootPart
            local currentCFrame = root.CFrame
            local lookVector = currentCFrame.LookVector
            
            -- Проверка на видимость и команду
            local shouldRotate = true
            if AntiAimConfig.TeamCheck then
                -- Простейшая проверка: если есть цель из вражеской команды
                local hasEnemy = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Team ~= LocalPlayer.Team and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        hasEnemy = true
                        break
                    end
                end
                if not hasEnemy then shouldRotate = false end
            end
            
            if AntiAimConfig.OnlyVisible then
                -- Проверка: есть ли видимый враг
                local hasVisibleEnemy = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Team ~= LocalPlayer.Team and p.Character then
                        local rootPart = p.Character:FindFirstChild("HumanoidRootPart")
                        if rootPart then
                            local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                            if onScreen then
                                hasVisibleEnemy = true
                                break
                            end
                        end
                    end
                end
                if not hasVisibleEnemy then shouldRotate = false end
            end
            
            if shouldRotate then
                -- Поворачиваем персонажа
                local newCFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(AntiAimAngle), 0)
                root.CFrame = newCFrame
            end
        end
    end

    -- ESP
    if ESPConfig.MasterSwitch then
        for player, data in pairs(ESPCache) do
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if root and hum and hum.Health > 0 then
                if ESPConfig.TeamCheck and player.Team == LocalPlayer.Team then
                    data.Box.Visible = false data.Tracer.Visible = false data.NameTag.Visible = false
                    data.DistTag.Visible = false data.HealthBar.Visible = false data.WeaponTag.Visible = false
                    for _, cl in pairs(data.Corners) do cl.Visible = false end
                    for _, l in pairs(data.Skeleton) do l.Visible = false end continue
                end
                
                local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
                local distance = (Camera.CFrame.Position - root.Position).Magnitude
                
                -- Only Visible check
                if ESPConfig.OnlyVisible and not onScreen then
                    data.Box.Visible = false data.Tracer.Visible = false data.NameTag.Visible = false
                    data.DistTag.Visible = false data.HealthBar.Visible = false data.WeaponTag.Visible = false
                    for _, cl in pairs(data.Corners) do cl.Visible = false end
                    for _, l in pairs(data.Skeleton) do l.Visible = false end
                    data.Highlight.Enabled = false
                    continue
                end
                
                if onScreen then
                    local sizeY = math.clamp((1000 / distance) * 2.2, 15, 320)
                    local sizeX = sizeY * 0.6
                    local boxX = pos.X - (sizeX / 2)
                    local boxY = pos.Y - (sizeY / 2)
                    local boxCenter = Vector2.new(pos.X, pos.Y)
                    
                    if ESPConfig.Boxes and distance <= ESPConfig.BoxesDist then
                        if ESPConfig.CornerBoxes then
                            data.Box.Visible = false
                            local cLength = math.clamp(sizeX * 0.25, 4, 25)
                            for _, cl in pairs(data.Corners) do cl.Color = ESPConfig.BoxesColor cl.Thickness = ESPConfig.BoxesThick cl.Visible = true end
                            data.Corners[1].From = Vector2.new(boxX, boxY) data.Corners[1].To = Vector2.new(boxX + cLength, boxY)
                            data.Corners[2].From = Vector2.new(boxX, boxY) data.Corners[2].To = Vector2.new(boxX, boxY + cLength)
                            data.Corners[3].From = Vector2.new(boxX + sizeX, boxY) data.Corners[3].To = Vector2.new(boxX + sizeX - cLength, boxY)
                            data.Corners[4].From = Vector2.new(boxX + sizeX, boxY) data.Corners[4].To = Vector2.new(boxX + sizeX, boxY + cLength)
                            data.Corners[5].From = Vector2.new(boxX, boxY + sizeY) data.Corners[5].To = Vector2.new(boxX + cLength, boxY + sizeY)
                            data.Corners[6].From = Vector2.new(boxX, boxY + sizeY) data.Corners[6].To = Vector2.new(boxX, boxY + sizeY - cLength)
                            data.Corners[7].From = Vector2.new(boxX + sizeX, boxY + sizeY) data.Corners[7].To = Vector2.new(boxX + sizeX - cLength, boxY + sizeY)
                            data.Corners[8].From = Vector2.new(boxX + sizeX, boxY + sizeY) data.Corners[8].To = Vector2.new(boxX + sizeX, boxY + sizeY - cLength)
                        else
                            for _, cl in pairs(data.Corners) do cl.Visible = false end
                            data.Box.Size = Vector2.new(sizeX, sizeY)
                            data.Box.Position = Vector2.new(boxX, boxY)
                            data.Box.Color = ESPConfig.BoxesColor
                            data.Box.Thickness = ESPConfig.BoxesThick
                            data.Box.Visible = true
                        end
                    else 
                        data.Box.Visible = false 
                        for _, cl in pairs(data.Corners) do cl.Visible = false end
                    end
                    
                    if ESPConfig.Tracers and distance <= ESPConfig.TracersDist then
                        data.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        data.Tracer.To = Vector2.new(pos.X, pos.Y + (sizeY / 2))
                        data.Tracer.Color = ESPConfig.TracersColor
                        data.Tracer.Visible = true
                    else data.Tracer.Visible = false end
                    
                    if ESPConfig.Names and distance <= ESPConfig.NamesDist then
                        data.NameTag.Text = string.upper(player.DisplayName)
                        data.NameTag.Color = ESPConfig.NamesColor
                        data.NameTag.Position = boxCenter + Vector2.new(ESPOffsets.Names.X * (sizeX/120), ESPOffsets.Names.Y * (sizeY/180))
                        data.NameTag.Visible = true
                    else data.NameTag.Visible = false end
                    
                    if ESPConfig.Distance and distance <= ESPConfig.DistanceDist then
                        data.DistTag.Text = "[" .. math.floor(distance) .. "M]"
                        data.DistTag.Color = ESPConfig.DistanceColor
                        data.DistTag.Position = boxCenter + Vector2.new(ESPOffsets.Distance.X * (sizeX/120), ESPOffsets.Distance.Y * (sizeY/180))
                        data.DistTag.Visible = true
                    else data.DistTag.Visible = false end
                    
                    if ESPConfig.Health and distance <= ESPConfig.HealthDist then
                        data.HealthBar.Size = Vector2.new(4, sizeY * (hum.Health / hum.MaxHealth))
                        local customHealthPos = boxCenter + Vector2.new(ESPOffsets.Health.X * (sizeX/120), ESPOffsets.Health.Y * (sizeY/180))
                        data.HealthBar.Position = Vector2.new(customHealthPos.X, boxY + (sizeY - data.HealthBar.Size.Y)/2)
                        data.HealthBar.Color = ESPConfig.HealthColor
                        data.HealthBar.Visible = true
                    else data.HealthBar.Visible = false end
                    
                    if ESPConfig.Weapon and distance <= ESPConfig.WeaponDist then
                        local tool = char:FindFirstChildOfClass("Tool")
                        data.WeaponTag.Text = string.upper(tool and tool.Name or "NONE")
                        data.WeaponTag.Color = ESPConfig.WeaponColor
                        data.WeaponTag.Position = boxCenter + Vector2.new(ESPOffsets.Weapon.X * (sizeX/120), ESPOffsets.Weapon.Y * (sizeY/180))
                        data.WeaponTag.Visible = true
                    else data.WeaponTag.Visible = false end

                    if ESPConfig.Skeleton and distance <= ESPConfig.SkeletonDist then
                        local head = char:FindFirstChild("Head")
                        local upperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                        local lowerTorso = char:FindFirstChild("LowerTorso") or upperTorso
                        local leftHand = char:FindFirstChild("LeftHand") or char:FindFirstChild("Left Arm")
                        local rightHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
                        local leftLeg = char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("Left Leg")
                        local rightLeg = char:FindFirstChild("RightLowerLeg") or char:FindFirstChild("Right Leg")

                        if head and upperTorso and leftLeg and rightLeg then
                            local parts = {head, upperTorso, lowerTorso, leftLeg, rightLeg, leftHand or upperTorso, rightHand or upperTorso}
                            local screenPoints = {}
                            for i, pt in ipairs(parts) do
                                local pPoint, _ = Camera:WorldToViewportPoint(pt.Position)
                                screenPoints[i] = Vector2.new(pPoint.X, pPoint.Y)
                            end
                            for _, l in pairs(data.Skeleton) do l.Color = ESPConfig.SkeletonColor l.Thickness = ESPConfig.SkeletonThick end
                            data.Skeleton[1].From = screenPoints[1] data.Skeleton[1].To = screenPoints[2] data.Skeleton[1].Visible = true
                            data.Skeleton[2].From = screenPoints[2] data.Skeleton[2].To = screenPoints[3] data.Skeleton[2].Visible = true
                            data.Skeleton[3].From = screenPoints[3] data.Skeleton[3].To = screenPoints[4] data.Skeleton[3].Visible = true
                            data.Skeleton[4].From = screenPoints[3] data.Skeleton[4].To = screenPoints[5] data.Skeleton[4].Visible = true
                            data.Skeleton[5].From = screenPoints[2] data.Skeleton[5].To = screenPoints[6] data.Skeleton[5].Visible = true
                            data.Skeleton[6].From = screenPoints[2] data.Skeleton[6].To = screenPoints[7] data.Skeleton[6].Visible = true
                        end
                    else
                        for _, l in pairs(data.Skeleton) do l.Visible = false end
                    end
                    
                    data.Highlight.Enabled = ESPConfig.Chams
                    if ESPConfig.Chams and distance <= ESPConfig.ChamsDist then 
                        data.Highlight.Adornee = char data.Highlight.FillColor = ESPConfig.ChamsColor
                    else data.Highlight.Enabled = false end
                else
                    data.Box.Visible = false data.Tracer.Visible = false data.NameTag.Visible = false data.DistTag.Visible = false
                    data.HealthBar.Visible = false data.WeaponTag.Visible = false data.Highlight.Enabled = false
                    for _, cl in pairs(data.Corners) do cl.Visible = false end
                    for _, l in pairs(data.Skeleton) do l.Visible = false end
                end
            else
                data.Box.Visible = false data.Tracer.Visible = false data.NameTag.Visible = false data.DistTag.Visible = false
                data.HealthBar.Visible = false data.WeaponTag.Visible = false data.Highlight.Enabled = false
                for _, cl in pairs(data.Corners) do cl.Visible = false end
                for _, l in pairs(data.Skeleton) do l.Visible = false end
            end
        end
    else
        for player, data in pairs(ESPCache) do
            data.Box.Visible = false data.Tracer.Visible = false data.NameTag.Visible = false
            data.DistTag.Visible = false data.HealthBar.Visible = false data.WeaponTag.Visible = false
            data.Highlight.Enabled = false
            for _, cl in pairs(data.Corners) do cl.Visible = false end
            for _, l in pairs(data.Skeleton) do l.Visible = false end
        end
    end

    if AimbotConfig.Enabled then
        FOVCircle.Radius = AimbotConfig.FOV
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Visible = true
        
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            if AimbotConfig.Hitchance < 100 and math.random(1, 100) > AimbotConfig.Hitchance then
                return
            end

            local targetPlayer = GetClosestPlayerToCrosshair()
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild(AimbotConfig.TargetPart) then
                local targetPos = targetPlayer.Character[AimbotConfig.TargetPart].Position
                local lookVector = CFrame.new(Camera.CFrame.Position, targetPos)
                
                local lerpFactor = 1
                if AimbotConfig.Smoothness > 0 then
                    lerpFactor = 1 / (1 + (AimbotConfig.Smoothness * 0.25))
                end
                
                Camera.CFrame = Camera.CFrame:Lerp(lookVector, lerpFactor)
            end
        end
    else
        FOVCircle.Visible = false
    end
end)

